# SCUM DB PRO environment example
# Скопируй файл в .env.local для локальной разработки или задай эти переменные на хостинге.
# Не коммить реальные пароли, токены и ключи в GitHub.

# PostgreSQL database connection
DATABASE_URL="postgresql://scumdbpro_user:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/scumdbpro"

# Admin panel credentials
ADMIN_USER="CHANGE_ME_ADMIN_USER"
ADMIN_PASSWORD="CHANGE_ME_STRONG_ADMIN_PASSWORD"
ADMIN_SESSION_SECRET="CHANGE_ME_LONG_RANDOM_SECRET_32_PLUS_CHARS"

# Public site URL
NEXT_PUBLIC_SITE_URL="https://scumdbpro.duckdns.org"

# Next.js / production
NODE_ENV="production"
NEXT_TELEMETRY_DISABLED="1"
